generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Country {
  id          String       @id @default(cuid())
  name        String       @unique
  slug        String       @unique
  flagEmoji   String?      @map("flag_emoji")
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  curations   Curation[]
  funds       Fund[]
  influencers Influencer[]
  websites    Website[]

  @@map("countries")
}

model Category {
  id                      String                  @id @default(cuid())
  name                    String                  @unique
  slug                    String                  @unique
  description             String?
  isActive                Boolean                 @default(true) @map("is_active")
  createdAt               DateTime                @default(now()) @map("created_at")
  updatedAt               DateTime                @updatedAt @map("updated_at")
  blogPosts               BlogPost[]
  fundCategories          FundCategory[]
  influencerCategories    InfluencerCategory[]
  redditChannelCategories RedditChannelCategory[]
  subCategories           SubCategory[]
  websiteCategories       WebsiteCategory[]
  websites                Website[]

  @@map("categories")
}

model SubCategory {
  id         String    @id @default(cuid())
  categoryId String    @map("category_id")
  name       String
  slug       String    @unique
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  category   Category  @relation(fields: [categoryId], references: [id])
  websites   Website[]

  @@map("sub_categories")
}

model Tag {
  id                String             @id @default(cuid())
  name              String             @unique
  slug              String             @unique
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  fundTags          FundTag[]
  influencerTags    InfluencerTag[]
  redditChannelTags RedditChannelTag[]
  websiteTags       WebsiteTag[]

  @@map("tags")
}

model PlanConfig {
  id            String      @id @default(cuid())
  name          String
  slug          String      @unique
  priceCents    Int         @map("price_cents")
  credits       Int
  billingType   BillingType @map("billing_type")
  stripePriceId String?     @map("stripe_price_id")
  features      Json        @default("[]")
  isActive      Boolean     @default(true) @map("is_active")
  sortOrder     Int         @default(0) @map("sort_order")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  isVisible     Boolean     @default(true) @map("is_visible")
  payments      Payment[]
  users         User[]

  @@map("plan_configs")
}

model User {
  id                 String         @id @default(uuid())
  email              String         @unique
  name               String?
  passwordHash       String?        @map("password_hash")
  authProvider       AuthProvider   @default(email) @map("auth_provider")
  planId             String?        @map("plan_id")
  creditsRemaining   Int            @default(1) @map("credits_remaining")
  stripeCustomerId   String?        @map("stripe_customer_id")
  emailVerifiedAt    DateTime?      @map("email_verified_at")
  emailVerifyToken   String?        @map("email_verify_token")
  resetToken         String?        @map("reset_token")
  resetTokenExpiry   DateTime?      @map("reset_token_expiry")
  failedLoginCount   Int            @default(0) @map("failed_login_count")
  lockedUntil        DateTime?      @map("locked_until")
  deletedAt          DateTime?      @map("deleted_at")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  stripeCustomerHash String?        @map("stripe_customer_hash")
  creditsResetAt     DateTime?      @map("credits_reset_at")
  referredByCreatorId String?       @map("referred_by_creator_id")
  curations          Curation[]
  notifications      Notification[]
  payments           Payment[]
  referralUsed       Referral[]     @relation("ReferredUser")
  referralsMade      Referral[]     @relation("ReferrerUser")
  affiliateProfile   AffiliateProfile?
  affiliateReferralsMade AffiliateReferral[] @relation("AffiliateReferrer")
  affiliateReferralSource AffiliateReferral[] @relation("AffiliateReferred")
  affiliateCommissionsEarned AffiliateCommission[] @relation("AffiliateCommissionEarner")
  affiliateCommissionsFromReferred AffiliateCommission[] @relation("AffiliateCommissionReferred")
  affiliatePayoutBatches AffiliatePayoutBatch[]
  contentCreatorProfile ContentCreatorProfile? @relation("ContentCreatorUser")
  contentCreatorReferral ContentCreatorReferral? @relation("ReferredUserFromCreator")
  serviceLeads       ServiceLead[]
  plan               PlanConfig?    @relation(fields: [planId], references: [id])

  @@index([email])
  @@index([stripeCustomerHash])
  @@map("users")
}

model AdminUser {
  id                   String                 @id @default(uuid())
  email                String                 @unique
  name                 String
  passwordHash         String                 @map("password_hash")
  totpSecret           String?                @map("totp_secret")
  totpEnabled          Boolean                @default(false) @map("totp_enabled")
  backupCodes          Json                   @default("[]") @map("backup_codes")
  role                 AdminRole              @default(admin)
  isActive             Boolean                @default(true) @map("is_active")
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")
  aiConfigs            AiConfig[]
  auditLogs            AuditLog[]
  betaConfigs          BetaConfig[]
  blogPosts            BlogPost[]
  emailProviderConfigs EmailProviderConfig[]
  paymentConfigs       PaymentGatewayConfig[]

  @@map("admin_users")
}

model Website {
  id                String            @id @default(cuid())
  name              String
  url               String            @unique
  type              WebsiteType
  da                Int               @default(0)
  countryId         String?           @map("country_id")
  categoryId        String?           @map("category_id")
  subCategoryId     String?           @map("sub_category_id")
  description       String?
  submissionUrl     String?           @map("submission_url")
  isActive          Boolean           @default(true) @map("is_active")
  isExcluded        Boolean           @default(false) @map("is_excluded")
  tagSlugs          String[]          @default([]) @map("tag_slugs")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  pa                Int               @default(0)
  spamScore         Int               @default(0) @map("spam_score")
  traffic           Int               @default(0)
  starRating        Int?              @map("star_rating")
  curationResults   CurationResult[]
  websiteCategories WebsiteCategory[]
  websiteTags       WebsiteTag[]
  category          Category?         @relation(fields: [categoryId], references: [id])
  country           Country?          @relation(fields: [countryId], references: [id])
  subCategory       SubCategory?      @relation(fields: [subCategoryId], references: [id])

  @@index([type, isActive])
  @@index([countryId, isActive])
  @@index([starRating, isActive])
  @@index([starRating, isActive], map: "websites_star_rating_idx")
  @@map("websites")
}

model WebsiteTag {
  websiteId String  @map("website_id")
  tagId     String  @map("tag_id")
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  website   Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@id([websiteId, tagId])
  @@map("website_tags")
}

model Curation {
  id                String           @id @default(uuid())
  userId            String           @map("user_id")
  productUrl        String           @map("product_url")
  countryId         String?          @map("country_id")
  keywords          String[]         @default([])
  description       String?
  status            CurationStatus   @default(pending)
  errorMessage      String?          @map("error_message")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  problemStatement  String?          @map("problem_statement")
  solutionStatement String?          @map("solution_statement")
  results           CurationResult[]
  country           Country?         @relation(fields: [countryId], references: [id])
  user              User             @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@map("curations")
}

model CurationResult {
  id              String            @id @default(cuid())
  curationId      String            @map("curation_id")
  websiteId       String?           @map("website_id")
  matchScore      Float             @map("match_score")
  matchReason     String?           @map("match_reason")
  section         CurationSection
  rank            Int
  userStatus      UserResultStatus? @map("user_status")
  userNotes       String?           @map("user_notes")
  createdAt       DateTime          @default(now()) @map("created_at")
  fundId          String?           @map("fund_id")
  influencerId    String?           @map("influencer_id")
  redditChannelId String?           @map("reddit_channel_id")
  curation        Curation          @relation(fields: [curationId], references: [id], onDelete: Cascade)
  fund            Fund?             @relation(fields: [fundId], references: [id])
  influencer      Influencer?       @relation(fields: [influencerId], references: [id])
  redditChannel   RedditChannel?    @relation(fields: [redditChannelId], references: [id])
  website         Website?          @relation(fields: [websiteId], references: [id])

  @@index([curationId, section, rank])
  @@map("curation_results")
}

model Payment {
  id                    String        @id @default(cuid())
  userId                String        @map("user_id")
  planId                String?       @map("plan_id")
  stripePaymentIntentId String?       @map("stripe_payment_intent_id")
  stripeSubscriptionId  String?       @map("stripe_subscription_id")
  stripeInvoiceId       String?       @map("stripe_invoice_id")
  amountCents           Int           @map("amount_cents")
  currency              String        @default("usd")
  status                PaymentStatus @default(pending)
  createdAt             DateTime      @default(now()) @map("created_at")
  providerPaymentId     String?       @map("provider_payment_id")
  paymentType           PaymentType   @default(plan) @map("payment_type")
  affiliateCommissions  AffiliateCommission[]
  plan                  PlanConfig?   @relation(fields: [planId], references: [id])
  user                  User          @relation(fields: [userId], references: [id])

  @@map("payments")
}

model PaymentGatewayConfig {
  id               String          @id
  provider         PaymentProvider
  publicKey        String?         @map("public_key")
  secretKey        String?         @map("secret_key")
  webhookSecret    String?         @map("webhook_secret")
  additionalConfig Json            @default("{}") @map("additional_config")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  updatedById      String?         @map("updated_by_id")
  isActive         Boolean         @default(false) @map("is_active")
  updatedBy        AdminUser?      @relation(fields: [updatedById], references: [id])

  @@map("payment_gateway_config")
}

model EmailProviderConfig {
  id               String        @id @default("default")
  provider         EmailProvider @default(resend)
  fromAddress      String        @map("from_address")
  apiKey           String?       @map("api_key")
  host             String?
  port             Int?
  username         String?
  password         String?
  useTls           Boolean       @default(true) @map("use_tls")
  additionalConfig Json          @default("{}") @map("additional_config")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  updatedById      String?       @map("updated_by_id")
  updatedBy        AdminUser?    @relation(fields: [updatedById], references: [id])

  @@map("email_provider_config")
}

model BetaConfig {
  id                      String     @id @default("default")
  enabled                 Boolean    @default(false)
  updatedAt               DateTime   @updatedAt @map("updated_at")
  updatedById             String?    @map("updated_by_id")
  pricingComparisonRows   Json       @default("[]") @map("pricing_comparison_rows")
  curationEnabledSections String[]   @default(["a", "b", "c", "d", "e", "f"]) @map("curation_enabled_sections")
  updatedBy               AdminUser? @relation(fields: [updatedById], references: [id])

  @@map("beta_config")
}

model ProcessedStripeEvent {
  eventId     String   @id @map("event_id")
  processedAt DateTime @default(now()) @map("processed_at")

  @@map("processed_stripe_events")
}

model BlogPost {
  id              String     @id @default(cuid())
  slug            String     @unique
  title           String
  excerpt         String?
  content         String
  featuredImage   String?    @map("featured_image")
  categoryId      String?    @map("category_id")
  authorId        String     @map("author_id")
  status          BlogStatus @default(draft)
  publishDate     DateTime?  @map("publish_date")
  metaTitle       String?    @map("meta_title")
  metaDescription String?    @map("meta_description")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  author          AdminUser  @relation(fields: [authorId], references: [id])
  category        Category?  @relation(fields: [categoryId], references: [id])

  @@index([status, publishDate(sort: Desc)])
  @@map("blog_posts")
}

model ServiceLead {
  id          String     @id @default(cuid())
  userId      String?    @map("user_id")
  name        String
  email       String
  phone       String?
  websiteUrl  String?    @map("website_url")
  serviceType String?    @map("service_type")
  message     String?
  status      LeadStatus @default(new)
  notes       String?
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  user        User?      @relation(fields: [userId], references: [id])

  @@map("service_leads")
}

model AuditLog {
  id        String    @id @default(cuid())
  adminId   String    @map("admin_id")
  action    String
  entity    String
  entityId  String    @map("entity_id")
  oldData   Json?     @map("old_data")
  newData   Json?     @map("new_data")
  ip        String?
  createdAt DateTime  @default(now()) @map("created_at")
  admin     AdminUser @relation(fields: [adminId], references: [id])

  @@index([adminId, createdAt(sort: Desc)])
  @@index([entity, entityId])
  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

model Referral {
  id             String   @id @default(cuid())
  referrerUserId String   @map("referrer_user_id")
  referredUserId String?  @map("referred_user_id")
  code           String   @unique
  status         String   @default("pending")
  createdAt      DateTime @default(now()) @map("created_at")
  referred       User?    @relation("ReferredUser", fields: [referredUserId], references: [id])
  referrer       User     @relation("ReferrerUser", fields: [referrerUserId], references: [id])

  @@map("referrals")
}

model AffiliateProfile {
  userId               String   @id @map("user_id")
  referralCode         String   @unique @map("referral_code")
  paypalEmail          String?  @map("paypal_email")
  starterCommissionPct Int      @default(25) @map("starter_commission_pct")
  hireUsCommissionPct  Int      @default(15) @map("hire_us_commission_pct")
  isActive             Boolean  @default(false) @map("is_active")
  isDisabledByAdmin    Boolean  @default(false) @map("is_disabled_by_admin")
  marketingChannel     String?  @map("marketing_channel")
  termsAcceptedAt      DateTime? @map("terms_accepted_at")
  enrolledAt           DateTime? @map("enrolled_at")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("affiliate_profiles")
}

model AffiliateReferral {
  id             String   @id
  referrerUserId String   @map("referrer_user_id")
  referredUserId String   @unique @map("referred_user_id")
  referralCode   String   @map("referral_code")
  createdAt      DateTime @default(now()) @map("created_at")
  referrer       User     @relation("AffiliateReferrer", fields: [referrerUserId], references: [id], onDelete: Cascade)
  referred       User     @relation("AffiliateReferred", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([referrerUserId])
  @@index([referralCode])
  @@map("affiliate_referrals")
}

model AffiliateCommission {
  id               String   @id
  affiliateUserId  String   @map("affiliate_user_id")
  referredUserId   String   @map("referred_user_id")
  paymentId        String?  @unique @map("payment_id")
  payoutBatchId    String?  @map("payout_batch_id")
  referralCode     String   @map("referral_code")
  paymentType      PaymentType @map("payment_type")
  commissionPct    Int      @map("commission_pct")
  amountCents      Int      @map("amount_cents")
  status           String   @default("pending")
  earnedAt         DateTime @map("earned_at")
  eligibleAt       DateTime @map("eligible_at")
  paidAt           DateTime? @map("paid_at")
  payoutMethod     String?  @map("payout_method")
  payoutReference  String?  @map("payout_reference")
  adminNote        String?  @map("admin_note")
  markedByAdminId  String?  @map("marked_by_admin_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  affiliate        User     @relation("AffiliateCommissionEarner", fields: [affiliateUserId], references: [id], onDelete: Cascade)
  referred         User     @relation("AffiliateCommissionReferred", fields: [referredUserId], references: [id], onDelete: Cascade)
  payment          Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  payoutBatch      AffiliatePayoutBatch? @relation(fields: [payoutBatchId], references: [id], onDelete: SetNull)

  @@index([affiliateUserId, status])
  @@index([status, eligibleAt])
  @@index([paidAt])
  @@index([payoutBatchId])
  @@map("affiliate_commissions")
}

model AffiliatePayoutBatch {
  id               String   @id
  affiliateUserId  String   @map("affiliate_user_id")
  totalAmountCents Int      @map("total_amount_cents")
  commissionCount  Int      @map("commission_count")
  payoutMethod     String   @map("payout_method")
  payoutReference  String?  @map("payout_reference")
  adminNote        String?  @map("admin_note")
  paidAt           DateTime @map("paid_at")
  createdByAdminId String?  @map("created_by_admin_id")
  status           String   @default("paid")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  affiliate        User     @relation(fields: [affiliateUserId], references: [id], onDelete: Cascade)
  commissions      AffiliateCommission[]

  @@index([affiliateUserId, paidAt])
  @@index([status, paidAt])
  @@map("affiliate_payout_batches")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_submissions")
}

model ContentCreatorProfile {
  userId         String   @id @map("user_id")
  isEnabled      Boolean  @default(false) @map("is_enabled")
  maxInvites     Int      @default(0) @map("max_invites")
  usedInvites    Int      @default(0) @map("used_invites")
  inviteToken    String   @unique @map("invite_token")
  expiresAt      DateTime? @map("expires_at")
  disabledAt     DateTime? @map("disabled_at")
  disabledReason String?  @map("disabled_reason")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  user           User     @relation("ContentCreatorUser", fields: [userId], references: [id], onDelete: Cascade)
  referrals      ContentCreatorReferral[] @relation("CreatorInviteReferrals")

  @@index([isEnabled])
  @@index([isEnabled, usedInvites, maxInvites])
  @@map("content_creator_profiles")
}

model ContentCreatorReferral {
  id             String   @id @default(cuid())
  creatorUserId  String   @map("creator_user_id")
  referredUserId String   @unique @map("referred_user_id")
  inviteToken    String   @map("invite_token")
  acceptedAt     DateTime @default(now()) @map("accepted_at")
  creator        ContentCreatorProfile @relation("CreatorInviteReferrals", fields: [creatorUserId], references: [userId], onDelete: Cascade)
  referredUser   User     @relation("ReferredUserFromCreator", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@unique([creatorUserId, referredUserId])
  @@index([creatorUserId, acceptedAt])
  @@index([inviteToken])
  @@map("content_creator_referrals")
}

model AiConfig {
  id          String     @id @default("default")
  baseUrl     String     @map("base_url")
  apiKey      String     @map("api_key")
  modelName   String     @map("model_name")
  maxTokens   Int        @default(4096) @map("max_tokens")
  temperature Float      @default(0.3)
  updatedAt   DateTime   @updatedAt @map("updated_at")
  updatedById String?    @map("updated_by_id")
  updatedBy   AdminUser? @relation(fields: [updatedById], references: [id])

  @@map("ai_config")
}

model Influencer {
  id                   String               @id @default(cuid())
  name                 String
  platform             InfluencerPlatform
  followersCount       Int                  @default(0) @map("followers_count")
  countryId            String?              @map("country_id")
  description          String?
  profileLink          String               @map("profile_link")
  email                String?
  isActive             Boolean              @default(true) @map("is_active")
  tagSlugs             String[]             @default([]) @map("tag_slugs")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  categorySlugs        String[]             @default([]) @map("category_slugs")
  starRating           Int?                 @map("star_rating")
  curationResults      CurationResult[]
  influencerCategories InfluencerCategory[]
  influencerTags       InfluencerTag[]
  country              Country?             @relation(fields: [countryId], references: [id])

  @@index([platform, isActive])
  @@index([starRating, isActive], map: "influencers_star_rating_idx")
  @@map("influencers")
}

model InfluencerTag {
  influencerId String     @map("influencer_id")
  tagId        String     @map("tag_id")
  influencer   Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  tag          Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([influencerId, tagId])
  @@map("influencer_tags")
}

model RedditChannel {
  id                      String                  @id @default(cuid())
  name                    String
  url                     String                  @unique
  weeklyVisitors          Int                     @default(0) @map("weekly_visitors")
  totalMembers            Int                     @default(0) @map("total_members")
  description             String?
  postingDifficulty       PostingDifficulty?      @map("posting_difficulty")
  isActive                Boolean                 @default(true) @map("is_active")
  tagSlugs                String[]                @default([]) @map("tag_slugs")
  createdAt               DateTime                @default(now()) @map("created_at")
  updatedAt               DateTime                @updatedAt @map("updated_at")
  categorySlugs           String[]                @default([]) @map("category_slugs")
  starRating              Int?                    @map("star_rating")
  curationResults         CurationResult[]
  redditChannelCategories RedditChannelCategory[]
  redditChannelTags       RedditChannelTag[]

  @@index([starRating, isActive], map: "reddit_channels_star_rating_idx")
  @@map("reddit_channels")
}

model RedditChannelTag {
  redditChannelId String        @map("reddit_channel_id")
  tagId           String        @map("tag_id")
  redditChannel   RedditChannel @relation(fields: [redditChannelId], references: [id], onDelete: Cascade)
  tag             Tag           @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([redditChannelId, tagId])
  @@map("reddit_channel_tags")
}

model Fund {
  id              String           @id @default(cuid())
  name            String
  logoUrl         String?          @map("logo_url")
  websiteUrl      String           @map("website_url")
  description     String?
  investmentStage InvestmentStage? @map("investment_stage")
  ticketSize      String?          @map("ticket_size")
  countryId       String?          @map("country_id")
  isActive        Boolean          @default(true) @map("is_active")
  tagSlugs        String[]         @default([]) @map("tag_slugs")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  categorySlugs   String[]         @default([]) @map("category_slugs")
  starRating      Int?             @map("star_rating")
  curationResults CurationResult[]
  fundCategories  FundCategory[]
  fundTags        FundTag[]
  country         Country?         @relation(fields: [countryId], references: [id])

  @@index([starRating, isActive], map: "funds_star_rating_idx")
  @@map("funds")
}

model FundTag {
  fundId String @map("fund_id")
  tagId  String @map("tag_id")
  fund   Fund   @relation(fields: [fundId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([fundId, tagId])
  @@map("fund_tags")
}

model WebsiteCategory {
  websiteId  String   @map("website_id")
  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  website    Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@id([websiteId, categoryId])
  @@map("website_categories")
}

model InfluencerCategory {
  influencerId String     @map("influencer_id")
  categoryId   String     @map("category_id")
  category     Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  influencer   Influencer @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  @@id([influencerId, categoryId])
  @@map("influencer_categories")
}

model RedditChannelCategory {
  redditChannelId String        @map("reddit_channel_id")
  categoryId      String        @map("category_id")
  category        Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  redditChannel   RedditChannel @relation(fields: [redditChannelId], references: [id], onDelete: Cascade)

  @@id([redditChannelId, categoryId])
  @@map("reddit_channel_categories")
}

model FundCategory {
  fundId     String   @map("fund_id")
  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  fund       Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@id([fundId, categoryId])
  @@map("fund_categories")
}

